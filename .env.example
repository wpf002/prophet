# Prophet environment configuration
# Copy to .env and fill in values

# Data paths
PROPHET_DATA_RAW=./data/raw
PROPHET_DATA_PROCESSED=./data/processed

# MLflow
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=prophet-benchmarks

# API server
PROPHET_API_HOST=0.0.0.0
PROPHET_API_PORT=8000
PROPHET_API_RELOAD=true

# Logging
LOG_LEVEL=INFO
